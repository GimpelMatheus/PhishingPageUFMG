                      <div class="card-horizontal"> 
                       <div class="row"> 
                        <div class="card-horizontal__media col-lg-12 col-md-6"> 
                         <div ocr-component-name="media" data-component-id="9b002e252846bf14b532f40bd58c2fca" class="media"> 
