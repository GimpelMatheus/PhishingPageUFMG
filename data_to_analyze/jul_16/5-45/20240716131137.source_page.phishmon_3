				const mr = {_: {BAD_MRCU: false,BUILD: "3a74e39",VERSION: 1720603307,isQA: false,HOST: "mail.ru",GEOMAP: undefined,HOSTNAME: "lf267.m.smailru.net",STYLE: ['//limg.imgsmail.ru/re/c/desktop-9d64c841.css','//limg.imgsmail.ru/re/c/app-44493c46.css','//limg.imgsmail.ru/re/c/theme-system-c562f91f4282.css'],SCRIPTS: ["/j/u-3b70178a.js"],XRAY_VERBOSE: false,UFID: "lyofnjz21nh",DEV_WHITELINE: false,TIMESTAMP: 1721135526878,TIMESTAMP_LOCAL: Date.now(),TIMEZONE: -10800,AUTH: false,REGION_ID: 234,PARENT_REGION_ID: 0,PAGE_ID: "17219398914581722134317469",VIEWPORT: {"ww":null,"wh":null},ACC_CNT: false,SITEZONE: 15,SITEID: 169,OMICRON_SEGMENTS: "MzUyM185Mzc1XyVEMCU5QSVEMSU4MyVEMSU4MCVEMSU4MSUyMCVEMSU4RSVEMCVCMCVEMCVCRCVEMSU4RiUyMCVEMCVCMiVEMCVCQyVEMCVCNSVEMSU4MSVEMSU4MiVEMCVCRSUyMCVEMCVCRCVEMCVCNSVEMSU4NCVEMSU4MiVEMCVCOF8lRDAlQUUlRDAlQjAlRDAlQkQlRDElOEM=",REFERRER: "function () { [native code] }",DEVICE: "desktop",BROWSER: "Firefox",isIE: false,PLATFORM: "Linux",CSRF: "8222904c395c430bab2dc7a66dcba516",MANUAL_REGION_NOT_RUSSIA: true,MEASURE_PIXEL_PERCENT: 0.01,HONEYPOT: '.i-pull-left .tgb, .grid__main-col div .news-item_tgb, .i-pull-left .news-item_tgb, .grid__main-col .tgb-wrapper, .pulse-lenta, .grid__rcol .rectangle-banner, @data-testid="search-container", .svelte-foobar.svelte-xxx',},switches: {isUkraine2022Tab:true,maxAccounts:20,pageHealthCheck:3500,updateAdOnAuthChange:true,updateAdOnTabTimeout:0,updateAdOnTimer:true,updateAdTimerDelay:30,updateAdTimerInnactive:300},mimic: {"cryptoKey":"5d0c6f0b8c2007cbf4e4ecce8abbcb3d","cryptoKeyId":"1","encryptPath":"res","adsRedirectRegExp":"an.yandex.ru/count"},omicronConfig: {"config_v":2729,"cond_s":"bf9379900a0fb29cb1f2411b7e679b0dbd545d0d035180436ba05d7a9a7ef24c","config":{"addWindowLastAdsBanner":false,"adviceOrder":"4","animatedCsat":true,"animatedTemperature":2,"animatedWeather":true,"asteroidWidgetsOrder":["vk","ok","cloud","vkjob","tv","games","combo","moymir","youla","deliveryclub","smotri"],"calendarAnimatingSubtitleEnabl