  left: 0;
  border-right-color: transparent !important;
  -webkit-transform: rotate(129deg);
  transform: rotate(129deg);
}

.circle-clipper.right.tp-yt-paper-spinner-lite .circle.tp-yt-paper-spinner-lite {
  left: -100%;
  border-left-color: transparent !important;
  -webkit-transform: rotate(-129deg);
  transform: rotate(-129deg);
}

.active.tp-yt-paper-spinner-lite .gap-patch.tp-yt-paper-spinner-lite::after,.active.tp-yt-paper-spinner-lite .circle-clipper.tp-yt-paper-spinner-lite .circle.tp-yt-paper-spinner-lite {
