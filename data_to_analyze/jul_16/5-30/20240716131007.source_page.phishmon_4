.circle-clipper.tp-yt-paper-spinner-lite {
  display: inline-block;
  position: relative;
  width: 50%;
  height: 100%;
  overflow: hidden;
}

.spinner-layer.tp-yt-paper-spinner-lite::after {
  content: "";
  left: 45%;
