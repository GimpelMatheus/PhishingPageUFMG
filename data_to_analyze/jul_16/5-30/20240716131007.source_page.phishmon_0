				 */
				const loadGoogleAdsGtag = () => {
						kit.loadGtag( 'AW-946162814' );
				}

				/**
				 * Loads and fires the Google Analytics 4.
				*/
				const fireGoogleAnalyticsFour = () => {
					const gtagOptions = {
