           <div class="grid-container"> 
            <div class="block-intro"> 
             <h2 class="h6" style="text-transform: uppercase; text-align: center;">Great Connections Start with a click OR SCAN</h2> 
             <h3 class="h2" style="text-align: center;">Sign up for a free account<br> and put Bitly to work</h3> 
            </div> 
            <div class="block-content"> 
             <ul class="tabs" data-deep-link-off="true" data-update-history-off="true" data-deep-link-smudge-off="true" data-deep-link-smudge-delay-off="500" data-tabs="" id="freehook-tabs"> 
              <li class="tabs-title is-active"> <a id="tab-short-link" href="#panel-short-link" aria-selected="true"> <img src="https://docrdsfx76ssb.cloudfront.net/static/1720612332/pages/wp-content/uploads/2024/04/icon_product-links.svg" alt="Link illustration symbolizing short links"> <span> Short link</span> </a> </li> 
              <li class="tabs-title"> <a id="tab-qr-code" href="#panel-qr-code"> <img src="https://docrdsfx76ssb.cloudfront.net/static/1720612332/pages/wp-content/uploads/2024/04/icon_product-qr-codes.svg" alt="Simplified QR Code illustration"> <span> QR Code</span> </a> </li> 
