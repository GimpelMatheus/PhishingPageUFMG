  <script>_satellite["_runScript3"](function(event, target, Promise) {
const eloquaHiddenInputs = _satellite.getVar("Eloqua Hidden Inputs");
const urlParams = new URLSearchParams(new URL(document.URL).searchParams);

// Only update referrer and utm_source if they are not already set in sessionStorage
if (!sessionStorage.getItem('referrer') && !sessionStorage.getItem('utm_source')) {
  // Check if there are any query string parameters
  if (!Array.from(urlParams.keys()).length) {
    const referrer = document.referrer;
    
    if (referrer) {
      const referrerUrl = new URL(referrer);
      const utmSource = referrerUrl.hostname.replace('www.', '').split('.')[0];
      
      // Store referrer and utm_source in sessionStorage
      sessionStorage.setItem('referrer', referrer);
      sessionStorage.setItem('utm_source', utmSource);
    }
  }
}

// Store UTM parameters if they exist in the URL
urlParams.forEach((value, key) => {
  if (eloquaHiddenInputs.includes(key)) {
    sessionStorage.setItem(key, value);
  }
});
});</script> 
