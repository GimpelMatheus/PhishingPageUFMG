    <div class="h-c-header__bar-underside"></div> 
    <div class="dd-menu"> 
     <nav class="dd-menu__nav"> 
      <div class="dd-menu__section dd-menu__section--hero"> 
       <div class="dd-menu__banner" data-dropdown-item="smb-subnav"> <span class="dd-menu__banner__header">For Small Businesses</span> 
        <p class="dd-menu__banner__text">Free and easy-to-use solutions for businesses of every size.</p> <a data-g-event="for enterprises" data-g-action="for small businesses: learn more" data-g-label="global nav" href="/about/small-business/" class="h-c-button h-c-button--primary h-c-button--reversed"> Learn more </a> 
       </div> 
       <div class="dd-menu__banner" data-dropdown-item="enterprise-subnav"> <span class="dd-menu__banner__header">For Enterprises</span> 
        <p class="dd-menu__banner__text">A single platform that integrates your advertising and analytics, so you can act on customer insights faster.</p> <a data-g-event="for enterprises" data-g-action="for enterprise: learn more" data-g-label="global nav" href="/about/enterprise/" class="h-c-button h-c-button--primary h-c-button--reversed"> Learn more </a> 
       </div> 
      </div> 
      <div class="dd-menu__section dd-menu__section--nav"> 
       <div class="dd-menu__nav-list-ctr" data-dropdown-item="smb-subnav"> 
        <ul class="dd-menu__nav-list"> 
         <li class="dd-menu__nav-item" aria-level="2"> <a data-g-event="for enterprises" data-g-action="for small businesses: analytics" data-g-label="global nav" href="/about/analytics/" class="dd-menu__nav-item__link "> <span class="dd-menu__nav-item__title">Analytics</span> <p class="dd-menu__nav-item__desc">Understand your customers so you can deliver better experiences.</p> </a> </li> 
         <li class="dd-menu__nav-item" aria-level="2"> <a data-g-event="for enterprises" data-g-action="for small businesses: tag manager" data-g-label="global nav" href="/about/tag-manager/" class="dd-menu__nav-item__link "> <span class="dd-menu__nav-item__title">Tag Manager</span> <p class="dd-menu__nav-item__desc">Manage all your tags without editing code.</p> </a> </li> 
        </ul> 
       </div> 
