is e cidadãos apaixonados.","Image":{"Url":"/th?id=OHR.AncientOrkney_PT-BR0835986378_1920x1080.webp","Wallpaper":"/th?id=OHR.AncientOrkney_PT-BR0835986378_1920x1200.jpg\u0026rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Explorando o passado","Title":"O assentamento neolítico de Skara Brae, Orkney, Escócia","Copyright":"© Paul Williams - FunkyStock/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz\u0026filters=WQOskey:\u0022HPQuiz_20240716_AncientOrkney\u0022\u0026FORM=HPQUIZ","BackstageUrl":"/search?q=Arqueologia+Brit%c3%a2nica\u0026form=hpcapt\u0026filters=HpDate:\u002220240716_0300\u0022","TriviaId":"HPQuiz_20240716_AncientOrkney"},"AudioContent":null,"VideoContent":null,"Ssd":"20240716_0300","FullDateString":"jul. 16, 2024"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"Image of the day","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"Learn more","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"Donate now","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"Quick fact:","LOC_HOMEPAGE_GALLERY_CARD_TITLE":"Recent Homepage images","LOC_HOMEPAGE_VERTICAL_SCROLL_GALLERY_IMAGE_ARIALABEL":"Homepage image for {0}","LOC_HOMEPAGE_ON_THIS_DAY_TITLE":"On this day in history","LOC_HOMEPAGE_ON_THIS_DAY_IMAGE_ARIALABEL":"On this day in {0}, {1}","LOC_HOMEPAGE_HOLIDAY_BTN_DONATE":"Donate","LOC_HOMEPAGE_SHARE_TOOLTIP":"Share today\u0027s Bing homepage","LOC_HOMEPAGE_WALLPAPERDOWNLOAD_TOOLTIP":"Download this image. Use of this image is restricted to wallpaper only.","LOC_MUSCARD_DOWNLOAD_LINK":"Download this image","LOC_HOMEPAGE_WALLPAPERNOTAVAILABLE":"This image is not available to download as wallpaper.","LOC_HOMEPAGE_INFO_TEXT":"Info","LOC_BING_WP_APP_LINK":"https://go.microsoft.com/fwlink/?linkid=2127455","LOC_BING_WP_APP_LINK_TEXT":"Get the new Bing Wallpaper app","LOC_BING_APP_TEXT":"Get Bing Wallpaper on your devices","LOC_BING_APP_LINK_PC":"https://bing.microsoftapp.