    <div class="wp-block-group global-footer__logos-container is-layout-flow wp-block-group-is-layout-flow"> 
     <div class="wp-block-group is-content-justification-left is-nowrap is-layout-flex wp-container-core-group-is-layout-24 wp-block-group-is-layout-flex"> <!-- The design calls for two logos, a small "mark" on mobile/tablet, and the full logo for desktops. --> 
