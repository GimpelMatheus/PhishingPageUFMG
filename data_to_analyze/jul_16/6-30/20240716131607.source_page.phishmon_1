         <span class="lp-lazy-image" style="max-width:1201px"><span class="lp-lazy-image__content" style="padding-top:calc(690/1201*100%)"><img src="https://wordpress.com/wp-content/uploads/2023/10/logos-2x-optimized.webp" loading="lazy" alt="" role="presentation" width="1201" height="690"></span></span>
        </div>
       </div>
      </div>
