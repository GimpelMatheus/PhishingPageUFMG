          <script type="text/javascript"> (function () { try { var initState = document.getElementById("initial-state"); var neoState = document.getElementById("neo-content"); if (!initState || !neoState) { return; } neoState.style.position = "absolute"; neoState.style.visibility = "hidden"; neoState.style.display = "block"; var height = neoState.offsetHeight; initState.firstElementChild.style.minHeight = height + "px"; neoState.style.position = ""; neoState.style.visibility = ""; neoState.style.display = ""; } catch (error) { if (error && error.message) { console.warn('Could not resize loading spinner with error: ' + error.message); } } })(); </script> 
