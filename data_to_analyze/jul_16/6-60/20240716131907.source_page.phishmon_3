.spinner-layer.tp-yt-paper-spinner-lite::after,.circle-clipper.tp-yt-paper-spinner-lite .circle.tp-yt-paper-spinner-lite {
  box-sizing: border-box;
  position: absolute;
  top: 0;
  border-width: var(--paper-spinner-stroke-width, 3px);
  border-radius: 50%;
}

