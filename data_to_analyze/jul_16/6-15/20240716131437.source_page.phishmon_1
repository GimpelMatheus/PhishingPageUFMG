           <ul class="clearfix nav-list"> 
            <li class=" dropDownNav_item" am-region="Solutions"> <span>Solutions <i class="arrow-updated right"></i></span> 
             <div class="nav_dropdown">
              <div class="digital_trust_solutions navItem"> 
               <div class="goback"> 
                <div class="goback--content"> <i class="arrow-updated left"></i>Back 
                </div> 
               </div> 
               <div class="column1" style="background-color: #fff;">
                <div class="list section">
                 <p class="heading jqOnHover" data-for="digital-trust" data-lineseparator="false" am-region="Digital Trust for:"> Digital Trust for: <i class="arrow-updated right"></i> </p> 
                </div> 
                <div class="list section">
                 <p class="heading jqOnHover" data-for="enterprise-it" data-lineseparator="false" am-region="Enterprise IT, PKI &amp; Identity"> Enterprise IT, PKI &amp; Identity <i class="arrow-updated right"></i> </p> 
                 <div class="level-one" am-region="DigiCert® Trust Lifecycle Manager"> 
                  <div class="level-one-title"> <a href="https://www.digicert.com/trust-lifecycle-manager" data-for="enterprise-it" class="txt-u-animate straight-line jqOnHover">DigiCert® Trust Lifecycle Manager</a> 
                  </div> 
                 </div> 
                </div> 
                <div class="list section">
                 <p class="heading jqOnHover" data-for="websites-servers" data-lineseparator="false" am-region="Websites &amp; Servers"> Websites &amp; Servers <i class="arrow-updated right"></i> </p> 
                 <div class="level-one" am-region="DigiCert CertCentral® TLS/SSL Manager"> 
                  <div class="level-one-title"> <a href="https://www.digicert.com/tls-ssl/certcentral-tls-ssl-manager" data-for="websites-servers" class="txt-u-animate straight-line jqOnHover">DigiCert CertCentral® TLS/SSL Manager</a> 
                  </div> 
                 </div> 
                 <div class="level-one" am-region="DigiCert® DNS Trust Manager"> 
                  <div class="level-one-title"> <a href="https://www.digicert.com/dns-trust-manager" data-for="websites-servers" class="txt-u-animate straight-line jqOnHover">DigiCert® DNS Trust Manager</a> 
                  </div> 
                 </div> 
                </div> 
                <div class="list section">
