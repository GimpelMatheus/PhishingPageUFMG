          <div class="site_logo"> <a href="https://www.digicert.com/"> <img loading="lazy" class="lazyload cmp-image__image objfit-contain " data-src="/content/dam/digicert/images/navigation/header/DigiCertLogo_MainNavigation.svg" alt="DigiCert Logo - TLS/SSL Digital Certificate Authority"> </a> 
          </div> 
