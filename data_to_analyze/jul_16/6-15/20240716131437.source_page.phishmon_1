er\"},\"brandfolder\":{\"cdnURL\":\"https://cdn.bfldr.com/S5BC9Y64/at/fhfr8x53hr7698gcgq7sqht/2023_New_Assets_Unitycom_Games_Desktop.mp4\",\"extension\":\"mp4\",\"id\":\"fhfr8x53hr7698gcgq7sqht\",\"muxHLSURL\":\"https://stream.mux.com/73lhkPNytcvI1jvwfdcNrIdKhZcE1H5C.m3u8\",\"thumbnailURL\":\"https://assets2.brandfolder.io/bf-boulder-prod/fhfr8x53hr7698gcgq7sqht/v/1143673545/element.png\",\"url\":\"https://assets2.brandfolder.io/bf-boulder-prod/fhfr8x53hr7698gcgq7sqht/v/1143673545/original/2023_New_Assets_Unity.com_Games_Desktop.mp4\"},\"action\":{\"title\":\"Learn more\",\"link\":{\"linkReference\":{\"title\":\"Games\",\"href\":{\"current\":\"/games\"},\"target\":\"_self\"}}}},{\"_type\":\"uniteCard\",\"title\":\"Industry\",\"description\":\"Get the creation tools and enterprise support you need to transform your CAD and 3D data into immersive apps and experiences for any device, anywhere.\",\"image\":{\"file\":{\"asset\":{\"url\":\"https://cdn.sanity.io/images/fuvbjjlp/production/38136612b8cfd9f4450a0345b7936baf21b7099a-1920x1080.png\",\"metadata\":{\"blurHash\":\"M45#nmD$9Ex^oz?wRiM_a~ogIStSkDITog\",\"lqip\":\"data:image/png;base64,\",\"dimensions\":{\"width\":1920,\"height\":1080}}}},\"alt\":\"Placeholder\"},\"brandfolder\":{\"cdnURL\":\"https://cdn.bfldr.com/S5BC9Y64/at/94rtsrcgn6bvcbffmtztst/U_ATM_ShoeSole-opt.mp4\",\"extension\":\"mp4\",\"id\":\"94rtsrcgn6bvcbffmtztst\",\"muxHLSURL\":\"https://stream.mux.com/guu300Rv01RwG4SC3obLds3sbWa02v2j18f.m3u8\",\"thumbnailURL\":\"https://assets2.brandfolder.io/bf-boulder-prod/94rtsrcgn6bvcbffmtztst/v/1090192048/element.png\",\"url\":\"https://assets2.brandfolder.io/bf-boulder-prod/94rtsrcgn6bvcbffmtztst/v/1090192048/original/U_ATM_ShoeSole-opt.mp4\"},\"action\":{\"title\":\"Learn more\",\"link\":{\"linkReference\":{\"title\":\"Industry Solution\",\"href\":{\"current\":\"/industry\"},\"target\":\"_self\"}}}},{\"_type\":\"uniteCard\",\"title\":\"Grow\",\"description\":\"Grow your app from day one with Unity's complete set of powerful tools, services, and expertise to turn it into a successful business.\",\"image\":{\"file\":{\"asset\":{\"url\":\"https://cdn.sanity.io/images/fuvbjjlp/production/1de7d8318f9166a6a248f77c0c6bff591a9aa8fe-800x450.png\",\"metadata\":{\"blurHash\":\"M03R{^oeMyIUM{xZt7bIRjRjt8xtM_ayWB\",\"lqip\":\"data:image/png;base64,\",\"dimensions\":{\"width\":800,\"height\":450}}}},\"alt\":\"Placeholder\"},\"brandfolder\":{\"cdnURL\":\"https://cdn.bfldr.com/S5BC9Y64/at/9b6xnjqv8hs528bqxk6qr8s/Grow_-_product_in_tablet.mp4\",\"extension\":\"mp4\",\"id\":\"9b6xnjqv8hs528bqxk6qr8s\",\"muxHLSURL\":\"https://stream.mux.com/SEyYotPXv2oqL01foheD2LFQ5olXjo9y8.m3u8\",\"thumbnailURL\":\"https://storage-us-gcs.bfldr.com/9b6xnjqv8hs528bqxk6qr8s/v/1179063719/element.png?Expires=1712168352\u0026KeyName=gcs-bfldr-prod\u0026Signature=S3-EvY-Vz3qNlv05oP6Fdbpai5M=\",\"url\":\"https://storage-us-gcs.bfldr.com/9b6xnjqv8hs528bqxk6qr8s/v/1179063719/original/Grow%20-%20product%20in%20tablet.mp4?Expires=1712168352\u0026KeyName=gcs-bfldr-prod\u0026Signature=jJqSFGcabQNPHrNlcwi60VjXKho=\"},\"action\":{\"title\":\"Learn more\",\"link\":{\"linkReference\":{\"title\":\"Grow\",\"href\":{\"current\":\"/grow\"},\"target\":\"_self\"}}}}],\"cardsBlog\":null},{\"_type\":\"fullScreenPreview\",\"title1\":\"Unity 6 Preview is now available\",\"description\":\"Get a head start using exciting new and updated features coming to Unity 6.\",\"action\":{\"title\":\"Learn more\",\"link\":{\"linkReference\":{\"title\":\"Unity 6 lp\",\"href\":{\"current\":\"/releases/unity-6\"},\"target\":\"_self\"}}},\"image\":{\"asset\":{\"url\":\"https://cdn.sanity.io/images/fuvbjjlp/production/8ffb24e3ae6d72971a7e5bf12b93805d52961cb5-3840x2160.jpg\",\"metadata\":{\"blurHash\":\"MB84*,_NIUD$s:.9%NRjMxRjM{og-;xvIU\",\"lqip\":\"data:image/jpeg;base64,\"}}}},{\"_type\":\"animatedGrid\",\"title\":\"Success stories\",\"description\":\"See how creators and studios around the world have achieved remarkable success with Unity’s solutions and services.\",\"actions\":[{\"title\":\"Case studies\",\"link\":{\"linkReference\":{\"title\":\"Resources - Case studies\",\"href\":{\"current\":\"https://unity.com/resources?filters=case%20studies\"},\"target\":\"_self\"}}},{\"title\":\"Made with Unity\",\"link\":{\"linkReference\":{\"title\":\"Made with Unity\",\"href\":{\"current\":\"/made-with-unity\"},\"target\":\"_self\"}}}],\"grid\":[{\"title1\":\"MARVEL SNAP\",\"title2\":\"by Second Dinner \",\"description\":\"How does the explosively popular MARVEL SNAP stay fueled by updates? Discover how the Second Dinner team is streamlining content creation and delivery.\",\"action\":{\"title\":\"Discover\",\"link\":{\"linkReference\":{\"title\":\"Marvel Snap case study\",\"href\":{\"current\":\"/case-study/marvel-snap\"},\"target\":\"_self\"}}},\"image\":{\"asset\":{\"url\":\"https://cdn.sanity.io/images/fuvbjjlp/production/9cf29b35f20f712d746614158d7727ccb7aaa58e-1920x1080.png\",\"metadata\":{\"blurHash\":\"M79s4cas0c-V$r9pI.Rtais+0{%2}uScT3\",\"lqip\":\"$24\"}}}},{\"title1\":\"Warhammer 40,000: Warpforge\",\"title2\":\"by Everguild\",\"description\":\"Bringing the vast Warhammer 40,000 universe into a free-to-play, cross-platform digital card game, Everguild achieved PC quality and top performance on a multitude of mobile devices.\",\"action\":{\"title\":\"Discover\",\"link\":{\"linkReference\":{\"title\":\"Warhammer 40,000: Warpforge case study\",\"href\":{\"current\":\"/case-study/warhammer-40000-warpforge\"},\"target\":\"_self\"}}},\"image\":{\"asset\":{\"url\":\"https://cdn.sanity.io/images/fuvbjjlp/production/dcdf406d8fc7f2239f8323da4853374427886fcf-1920x1080.jpg\",\"metadata\":{\"blurHash\":\"MaHw_J9H${jvIV~URQs+t6RjE2ozNHxYxt\",\"lqip\":\"data:image/jpeg;base64,\"}}}},{\"title1\":\"Subway Surfers\",\"title2\":\"by SYBO\",\"description\":\"From a free-spirited urban culture highlighting hip-hop and graffiti, SYBO’s founders dreamed up what grew to be the defining game of the endless-runner genre: Subway Surfers. \",\"action\":{\"title\":\"Discover\",\"link\":{\"linkReference\":{\"title\":\"Subway Surfers case study\",\"href\":{\"current\":\"/case-study/subway-surfers\"},\"target\":\"_self\"}}},\"image\":{\"asset\":{\"url\":\"https://cdn.sanity.io/images/fuvbjjlp/production/311af65917e92f877e62b024a165c5bd71bd6ea9-5760x3840.jpg\",\"metadata\":{\"blurHash\":\"VFHd:F^O00Nb0fAB.7RPrC+]3E9Z}sxus+9bxuMxo~%M\",\"lqip\":\"data:image/jpeg;base64,\"}}}},{\"title1\":\"Please, Touch the Artwork\",\"title2\":\"by Thomas Waterzooi\",\"description\":\"How does a team of one transform generative art into a captivating mobile game? Thomas Waterzooi certainly knows the answer with his award-winning hit Please, Touch the Artwork.\",\"action\":{\"title\":\"Discover\",\"link\":{\"linkReference\":{\"title\":\"Please, Touch the Artwork case study\",\"href\":{\"current\":\"/case-study/please-touch-the-artwork\"},\"target\":\"_self\"}}},\"image\":{\"asset\":{\"url\":\"https://cdn.sanity.io/images/fuvbjjlp/production/2728c3a9cfbc5bb1626cf1ce048e1ea872b70db1-2560x1440.png\",\"metadata\":{\"blurHash\":\"MIRKZ*~9~90M:4;CNL9x=^,.zARkxBkDKR\",\"lqip\":\"$25\"}}}},{\"title1\":\"Bleak Sword DX\",\"title2\":\"by more8bit\",\"description\":\"How did more8bit build on a mobile game’s success and deliver an enhanced version to more players? Discover Bleak Sword DX’s story featuring updated controls, visuals, and a brand-new campaign.\",\"action\":{\"title\":\"Discover\",\"link\":{\"linkReference\":{\"title\":\"more8bit case study\",\"href\":{\"current\":\"/case-study/more8bit\"},\"target\":\"_self\"}}},\"image\":{\"asset\":{\"url\":\"https://cdn.sanity.io/images/fuvbjjlp/production/c5a6d7d4c59d6ee9fabd5a820cf3dc34ad48d785-3840x2160.png\",\"metadata\":{\"blurHash\":\"M19G8bACm,MK00?_%f:,=|pH02Ip={9t}@\",\"lqip\":\"$26\"}}}},{\"title1\":\"Timberborn\",\"title2\":\"by Mechanistry\",\"description\":\"How did a small team create a complex city-builder UI? When Timberborn became an early-access Steam hit, Mechanistry quickly iterated an intuitive UI for its rapidly growing playerbase.\",\"action\":{\"title\":\"Discover\",\"link\":{\"linkReference\":{\"title\":\"Timberborn case study\",\"href\":{\"current\":\"/case-study/timberborn\"},\"target\":\"_self\"}}},\"image\":{\"asset\":{\"url\":\"https://cdn.sanity.io/images/fuvbjjlp/production/1c462435cc320496d9fc1f03dad10f3950f57288-3480x1260.png\",\"metadata\":{\"blurHash\":\"DJDJOxay01oz-:~pofROkCN2\",\"lqip\":\"data:image/png;base64,\"}}}},{\"title1\":\"Safer communities\",\"title2\":\"with Hi-Rez\",\"description\":\"Tony Jones, a lead producer on Rogue Company, shares tips for cultivating trust and safety among players in this primer to his Unite 2023 session.\",\"action\":{\"title\":\"Discover\",\"link\":{\"linkReference\":{\"title\":\"Trust and safety primer for game communities blog\",\"href\":{\"current\":\"https://blog.unity.com/games/trust-and-safety-primer-for-game-communities\"},\"target\":\"_self\"}}},\"image\":{\"asset\":{\"url\":\"https://cdn.sanity.io/images/fuvbjjlp/production/b602de9824796c562c4f512af98ebbfbdd230095-2048x1114.png\",\"metadata\":{\"blurHash\":\"MTG+US9{_NE2%2TMxZM|smM{X9j?MxofbG\",\"lqip\":\"$27\"}}}},{\"title1\":\"Made with Unity September highlights\",\"description\":\"Read our monthly roundup celebrating all the amazing games, apps, and accomplishments from Unity creators around the world.\",\"action\":{\"title\":\"Discover\",\"link\":{\"linkReference\":{\"title\":\"Made with Unity September 2023 blog\",\"href\":{\"current\":\"https://blog.unity.com/news/made-with-unity-monthly-roundup-september-2023 \"},\"target\":\"_self\"}}},\"image\":{\"asset\":{\"url\":\"https://cdn.sanity.io/images/fuvbjjlp/production/e9f65ecab31163b051d1da717302b7432134da46-2048x1114.png\",\"metadata\":{\"blurHash\":\"MEFqX+V[00I;~D^5sCADsl-U9EkVO?s9$i\",\"lqip\":\"$28\"}}}},{\"title1\":\"Evil Wizard\",\"title2\":\"by Rubber Duck Games\",\"description\":\"Follow the journey of developing a boss fight for Evil Wizard – from design and prototyping to animation and more.\",\"action\":{\"title\":\"Discover\",\"link\":{\"linkReference\":{\"title\":\"Rubber Duck Games blog\",\"href\":{\"current\":\"https://blog.unity.com/games/how-rubber-duck-games-developed-evil-wizard-boss-fight\"},\"target\":\"_self\"}}},\"image\":{\"asset\":{\"url\":\"https://cdn.sanity.io/images/fuvbjjlp/production/ba5a55f9e688fc959502aca312f8e23e9d52e9fd-2048x1114.png\",\"metadata\":{\"blurHash\":\"M9CFSL0#0e{_AD^6MxXmNerqELIo-WofOY\",\"lqip\":\"$29\"}}}}]},{\"_type\":\"uniteCards\",\"theme\":\"light\",\"title\":\"Deep resources, dynamic community\",\"filters\":null,\"actions\":null,\"cards\":[{\"_type\":\"uniteCard\",\"title\":\"Resources\",\"description\":\"Get started and finish faster with step-by-step help, knowledge base, Issue Tracker, and more.\",\"image\":null,\"action\":{\"title\":\"Learn more\",\"link\":{\"linkReference\":{\"title\":\"Developer Tools\",\"href\":{\"current\":\"/developer-tools\"},\"target\":\"_self\"}}}},{\"_type\":\"uniteCard\",\"title\":\"Learn\",\"description\":\"Explore online learning paths, certifications, institutional licenses, tools for educators, and more.\",\"image\":null,\"action\":{\"title\":\"Learn more \",\"link\":{\"linkReference\":{\"title\":\"Learn\",\"href\":{\"current\":\"/learn\"},\"target\":\"_self\"}}}},{\"_type\":\"uniteCard\",\"title\":\"Community\",\"description\":\"Join the worldwide network of Unity creators, from hobbyists to pros, who connect to learn, share, and inspire.\",\"image\":null,\"action\":{\"title\":\"Learn more\",\"link\":{\"linkReference\":{\"title\":\"Community\",\"href\":{\"current\":\"/community\"},\"target\":\"_self\"}}}}],\"cardsBlog\":null},{\"_type\":\"uniteCards\",\"theme\":\"dark\",\"title\":\"Subscription plans\",\"filters\":null,\"actions\":[{\"title\":\"Plans and pricing\",\"link\":{\"linkReference\":{\"title\":\"Pricing\",\"href\":{\"current\":\"/pricing\"},\"target\":\"_self\"}}}],\"cards\":[{\"_type\":\"cardSubscription\",\"title\":\"Personal\",\"description\":\"Bring your vision to life with free access to the most widely used game engine in the world.\",\"image\":null,\"action\":{\"title\":\"Learn more\",\"link\":{\"linkReference\":{\"title\":\"Unity Personal PDP\",\"href\":{\"current\":\"/products/unity-personal\"},\"target\":\"_self\"}}}},{\"_type\":\"cardSubscription\",\"title\":\"Pro\",\"description\":\"Unlock your team’s potential with the tools professionals use to create hit games across devices and platforms. \",\"image\":null,\"action\":{\"title\":\"Learn more\",\"link\":{\"linkReference\":{\"title\":\"Unity Pro PDP\",\"href\":{\"current\":\"/products/unity-pro\"},\"target\":\"_self\"}}}},{\"_type\":\"cardSubscription\",\"title\":\"Enterprise\",\"description\":\"Manage complex real-time 3D projects with expert support and creation tools that scale for teams of any size.\",\"image\":null,\"action\":{\"title\":\"Learn more\",\"link\":{\"linkReference\":{\"title\":\"Unity Enterprise PDP\",\"href\":{\"current\":\"/products/unity-enterprise\"},\"target\":\"_self\"}}}}],\"cardsBlog\":null},{\"_type\":\"footnote\",\"content\":[{\"markDefs\":[],\"children\":[{\"_type\":\"span\",\"marks\":[],\"text\":\"Disclaimers\",\"_key\":\"dd14e47c1699\"}],\"_type\":\"block\",\"style\":\"normal\",\"_key\":\"fb38569a7b4d\"},{\"level\":1,\"_type\":\"block\",\"style\":\"normal\",\"_key\":\"cc47ae0a4eff\",\"listItem\":\"number\",\"markDefs\":[],\"children\":[{\"marks\":[],\"text\":\"Creator credits: Bleak Sword DX, More8bit, Devolver Digital | GTFO, 10 Chambers | Laika: Aged Through Blood, Brainwash Gang, Headup Publishing | Muhammad Ali, Showmax Game Changers, Chocolate Tribe | Sea of Stars, Sabotage Studios | BattleBit Remastered, SgtOkiDoki, Vilaskis, TheLiquidHorse\",\"_key\":\"48e3aac63fbe\",\"_type\":\"span\"}]},{\"level\":1,\"_type\":\"block\",\"style\":\"normal\",\"_key\":\"58ac06ba02e1\",\"listItem\":\"number\",\"markDefs\":[],\"children\":[{\"_type\":\"span\",\"marks\":[],\"text\":\"As of Decem