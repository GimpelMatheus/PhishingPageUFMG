       <div class="mzp-c-picto-body"> <a href="/en-US/products/vpn/" class="mzp-c-button mzp-t-secondary" id="homepage-get-mozilla-vpn" data-cta-text="Get Mozilla VPN" data-cta-type="link">Get Mozilla VPN</a> 
       </div> </li> <!-- Monitor --> 
      <li class="mzp-c-picto"> <img loading="lazy" src="https://www.mozilla.org/media/protocol/img/logos/firefox/monitor/logo.d97e5516f9e6.svg" alt="" class="mzp-c-picto-image" width="50" height="50"> <h3 class="mzp-c-picto-heading">Protect your private info from data brokers</h3> 
