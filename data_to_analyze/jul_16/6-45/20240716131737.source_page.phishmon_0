     <div class="container responsivegrid digicert-body aem-GridColumn aem-GridColumn--default--12"> 
      <div id="pencil-banner-active" class="cmp-container" am-region="Body"> 
       <div class="separator"> 
        <div class="cmp-separator" style="margin-top:0px;margin-bottom:80px;"> 
        </div> 
       </div> 
       <div class="pencil-banner"> 
        <div class="banner" am-region="pencil-banner-homepage" style="background-color:#E9EEF1;
     		color:#015a99"> 
         <center> <b>ENTRUST CUSTOMERS: MIGRATE TO DIGICERT TO KEEP YOUR CERTIFICATES SAFE.</b> <a href="https://www.digicert.com/campaigns/entrust-certificate-distrust" target="_self" style="color:#0f9dff">LEARN MORE &gt;</a> 
         </center> 
        </div> 
       </div> 
       <div class="separator"> 
        <div class="cmp-separator" style="margin-top:0px;margin-bottom:-30px;"> 
        </div> 
       </div> 
       <div class="custom-carousel carousel panelcontainer"> 
        <div class="cmp-carousel" role="group" aria-roledescription="carousel" data-cmp-is="carousel" data-cmp-delay="5000"> 
         <div class="cmp-carousel__content"> 
          <div class="cmp-carousel__item cmp-carousel__item--active" role="tabpanel" aria-label="Slide 1 of 5" data-cmp-hook-carousel="item">
           <div class="heroimage cmp-image vspacebtncomp-heroimage"> 
            <div class="grid-12"> 
             <div class="img-container fill-gridgap full-grid-width absolute
				noBgColor
				mbg-blue" style="background-color:;"> 
              <img loading="lazy" src="/content/dam/digicert/images/homepage/entrust-webinar-homepage-hero.png" alt="Entrust Webinar Homepage Hero Image" style="position:absolute;
					 top:-20px; right:0px;
					 bottom:0px;left:0px;"> 
             </div> 
             <div class="descriptionBox left vAlignTop "> 
              <div class="description cmp-text" style="color:#fff;">
               <h1 style="padding-right: 25.0%;">The Entrust Distrust</h1> 
               <h3 style="padding-right: 30.0%;">What Happened, What it Means, and What Steps to Take</h3> 
               <h6>WEBINAR</h6> 
               <h5 style="padding-right: 35.0%;">We helped thousands navigate the Symantec distrust in 2018. Join us for an experience-backed roadmap to avoiding disruption from the Entrust distrust.<br> &nbsp;</h5> 
              </div> 
              <div class="btn-container vertical left" am-region="hp-hero-control-01-survey"> <a href="https://digicert.registration.goldcast.io/events/6e4d709a-e4fe-4d04-bdc7-b9fd44807c9b" class="btn primary blue" target="_blank">WATCH NOW</a> 
              </div> 
             </div> 
            </div> 
           </div> 
          </div> 
          <div class="cmp-carousel__item" role="tabpanel" aria-label="Slide 2 of 5" data-cmp-hook-carousel="item">
           <div class="heroimage cmp-image vspacebtncomp-heroimage"> 
            <div class="grid-12"> 
             <div class="img-container fill-gridgap full-grid-width absolute
				noBgColor
				mbg-blue" style="background-color:;"> 
              <img loading="lazy" src="/content/dam/digicert/images/homepage/homepage-entrust-distrust-hero.png" alt="Entrust Distrust Homepage Hero" style="position:absolute;
					 top:-20px; right:0px;
					 bottom:0px;left:0px;"> 
             </div> 
             <div class="descriptionBox left vAlignTop "> 
              <div class="description cmp-text" style="color:#fff;">
               <h1 style="padding-right: 35.0%;">Distrust of Entrust Certificates</h1> 
               <h5 style="padding-right: 39.0%;">If you have questions about maintaining your TLS web security following Google’s announcement about distrusting Entrust, we’re here to help.</h5> 
               <h5 style="padding-right: 39.0%;">&nbsp;</h5> 
              </div> 
              <div class="btn-container vertical left" am-region="hp-hero-control-01-survey"> <a href="https://www.digicert.com/campaigns/entrust-certificate-distrust" class="btn primary blue" target="_self">LEARN MORE</a> 
              </div> 
             </div> 
            </div> 
           </div> 
          </div> 
          <div class="cmp-carousel__item" role="tabpanel" aria-label="Slide 3 of 5" data-cmp-hook-carousel="item">
           <div class="heroimage cmp-image vspacebtncomp-heroimage"> 
            <div class="grid-12"> 
             <div class="img-container fill-gridgap full-grid-width absolute
				noBgColor
				mbg-blue" style="background-color:;"> 
              <img loading="lazy" src="/content/dam/digicert/images/homepage/pqc-wrd-homepage-hero.png" alt="PQC World Readiness Day Homepage Hero Image" style="position:absolute;
					 top:-20px; right:0px;
					 bottom:0px;left:0px;"> 
             </div> 
             <div class="descriptionBox left vAlignTop "> 
              <div class="description cmp-text" style="color:#fff;">
               <h1 style="padding-right: 39.0%;">World Quantum Readiness Day</h1> 
               <h5 style="padding-right: 39.0%;">Encryption as we know it is under threat. But this September, we’re uniting the world to fight back—and this is one revolution that <i>will</i> be televised.</h5> 
               <h5>&nbsp;</h5> 
              </div> 
              <div class="btn-container vertical left" am-region="hp-hero-control-02-pqc-wrd"> <a href="https://www.digicert.com/world-quantum-readiness-day" class="btn primary blue" target="_self">SAVE THE DATE</a> 
              </div> 
             </div> 
            </div> 
           </div> 
          </div> 
          <div class="cmp-carousel__item" role="tabpanel" aria-label="Slide 4 of 5" data-cmp-hook-carousel="item">
           <div class="heroimage cmp-image vspacebtncomp-heroimage"> 
            <div class="grid-12"> 
             <div class="img-container fill-gridgap full-grid-width absolute
				noBgColor
				mbg-blue" style="background-color:;"> 
              <img loading="lazy" src="/content/dam/digicert/images/homepage/pqc-insights-homepage-hero.png" style="position:absolute;
					 top:-20px; right:0px;
					 bottom:0px;left:0px;"> 
             </div> 
             <div class="descriptionBox left vAlignTop "> 
              <div class="description cmp-text" style="color:#fff;">
               <h1 style="padding-right: 39.0%;">The quantum reality check</h1> 
               <h5 style="padding-right: 36.0%;">The revolution is here. Advances in quantum computing mean the time to start building your Post-Quantum Cryptography infrastructure is today.</h5> 
