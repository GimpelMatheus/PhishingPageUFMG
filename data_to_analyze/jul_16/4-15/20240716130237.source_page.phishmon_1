					var buttonId = elem.id.split("_").pop();
	                	liveagent.showWhenOffline(buttonId,elem);
	            }
			}
		});
		function startChat(buttonId) {
			liveagent.startChat(buttonId.split("_").pop());
		}
	</script> 
