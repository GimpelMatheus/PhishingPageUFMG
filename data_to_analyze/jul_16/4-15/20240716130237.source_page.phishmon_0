         <div data-category="advertising" class="awsccc-cs-s-container">
          <h3 class="awsccc-cs-s-title">Advertising</h3>
          <div class="awsccc-cs-s-text">
           <p class="awsccc-cs-s-paragraph">Advertising cookies may be set through our site by us or our advertising partners and help us deliver relevant marketing content. If you do not allow these cookies, you will experience less relevant advertising.</p>
          </div>
          <div class="awsccc-cs-s-action">
           <div>
            <div class="awsccc-cs-s-cb-outer">
             <div class="awscc-u-cb-checkbox-container" data-id="awsccc-u-cb-advertising-container">
