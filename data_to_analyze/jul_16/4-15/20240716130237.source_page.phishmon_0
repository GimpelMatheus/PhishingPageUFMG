        var key = keys[i];
        var shouldDelete = true;
        exceptions.forEach(function (val) {
            if (key !== null && key.lastIndexOf(val) !== -1) {
                shouldDelete = false;
            }
        });
        if (key && shouldDelete) {
            storage.removeItem(key);
        }
    };
    for (var i = 0; i < keys.length; i++) {
        _loop_1(i);
    }
}
clearStorage();
