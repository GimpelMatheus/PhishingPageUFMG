*,*::before,*::after{box-sizing:inherit;}/*!sc*/
html{box-sizing:border-box;color:rgb(35,49,59);font-family:ABCRepro-Medium,'Helvetica Neue',Helvetica,Arial,sans-serif;-webkit-text-size-adjust:100%;text-size-adjust:100%;font-size:16px;-webkit-font-smoothing:antialiased;font-variant-numeric:lining-nums;font-feature-settings:"lnum";}/*!sc*/
#root{min-height:calc(100vh - 100px);}/*!sc*/
body,form{margin:0;padding:0;overscroll-behavior-y:none;}/*!sc*/
button,input{font-family:ABCRepro-Medium,'Helvetica Neue',Helvetica,Arial,sans-serif;}/*!sc*/
blockquote,button,dl,dd,h1,h2,h3,h4,h5,h6,figure,p,pre{margin:0;}/*!sc*/
h1,h2,h3,h4,h5,h6{font-weight:500;}/*!sc*/
h1{-webkit-letter-spacing:-0.06em;-moz-letter-spacing:-0.06em;-ms-letter-spacing:-0.06em;letter-spacing:-0.06em;}/*!sc*/
h2,h3,h4,h5{-webkit-letter-spacing:-0.05em;-moz-letter-spacing:-0.05em;-ms-letter-spacing:-0.05em;letter-spacing:-0.05em;}/*!sc*/
h6{-webkit-letter-spacing:-0.04em;-moz-letter-spacing:-0.04em;-ms-letter-spacing:-0.04em;letter-spacing:-0.04em;}/*!sc*/
p:first-child,p{margin-top:0;}/*!sc*/
img{border:0;}/*!sc*/
fieldset,legend{margin:0;padding:0;border:0;}/*!sc*/
acronym{cursor:help;}/*!sc*/
time{cursor:default;}/*!sc*/
em{font-style:italic;}/*!sc*/
sup{vertical-align:top;}/*!sc*/
.show{display:-webkit-box;display:-webkit-flex;display:-ms-flexbox;display:flex;}/*!sc*/
.show_block{display:block;}/*!sc*/
.rotate_arrow{-webkit-transform:rotate(-180deg);-ms-transform:rotate(-180deg);transform:rotate(-180deg);}/*!sc*/
[tabindex='-1']:focus{outline:none !important;}/*!sc*/
ol,ul{list-style-type:none;margin:0;padding:0;}/*!sc*/
a{color:inherit;}/*!sc*/
body.no-scroll{overflow:hidden;}/*!sc*/
