	            for(var i=0;i<liveagentchatbtnlist_online.length;i++){
	            	var elem = liveagentchatbtnlist_online[i];
					var buttonId = elem.id.split("_").pop();
	                	liveagent.showWhenOnline(buttonId,elem);
	            }
	            for(var i=0;i<liveagentchatbtnlist_offline.length;i++){
	            	var elem = liveagentchatbtnlist_offline[i];
					var buttonId = elem.id.split("_").pop();
	                	liveagent.showWhenOffline(buttonId,elem);
	            }
			}
		});
		function startChat(buttonId) {
			liveagent.startChat(buttonId.split("_").pop());
		}
	</script> 
  <script>
var bodyElem = document.querySelector('body');
var dataLang = bodyElem.dataset.lang
if(dataLang.toLowerCase() == "en-us" || dataLang.toLowerCase() == "en"){
    var el = document.querySelector(".experiencefragment #OldNavigationHeader");
    if(el!=null)
        el.innerHTML = "";
}
else{
    var el = document.querySelector(".experiencefragment #NewNavigationHeader");
    if(el!=null)
        el.innerHTML = "";
}
</script> 
  <script async src="/etc.clientlibs/digicert/clientlibs/clientlib-cif.js"></script> 
 </body>
</html>
