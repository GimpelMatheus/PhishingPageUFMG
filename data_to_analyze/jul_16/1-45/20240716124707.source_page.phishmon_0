    <div class="lb-data-attr-wrapper data-attr-wrapper" data-da-type="so" data-da-so-category="monitoring" data-da-so-language="en" data-da-so-name="homepage" data-da-so-type="viewport" data-da-so-version="homepage-hero" data-da-so-url="/"> 
     <div class="lb-mbox js-mbox" data-lb-comp="mbox" data-lb-comp-ignore="true" data-mbox="en_homepage-hero"> 
      <div class="lb-grid lb-row lb-row-max-none lb-snap"> 
       <div class="lb-col lb-tiny-24 lb-mid-24"> 
        <div class="lb-carousel-wrapper light"> 
         <div id="aws-element-1f6e519d-2f85-4352-aae6-c89ca1fa7ad7" class="lb-carousel lb-carousel-arrows-outside" style="padding-left:0px; padding-right:0px;" data-lb-comp="carousel" data-items="1" data-smart-speed="450" data-autoplay-timeout="5000" data-stage-padding="40" data-center="true" data-loop="true" data-withid="aws-element-1f6e519d-2f85-4352-aae6-c89ca1fa7ad7" data-theme="light" data-prev-text="Previous Slide" data-next-text="Next Slide" data-slide-text="Slide"> 
          <div class="data-attr-wrapper lb-small-pad lb-wrapper-url lb-carousel-item-inner-wrapper" style="padding-bottom:20px;" data-da-type="ha" data-da-channel="ha" data-da-language="en" data-da-placement="hero1" data-da-campaign="acq_aws_takeover-default" data-da-content="awssm-evergreen_pac_default" data-da-trk="ha_awssm-evergreen_pac_default"> <a href="https://portal.aws.amazon.com/gp/aws/developer/registration/index.html?exp=default&amp;sc_icampaign=acq_aws_takeover-default&amp;sc_ichannel=ha&amp;sc_icontent=awssm-evergreen_pac_default&amp;sc_iplace=hero&amp;trk=ha_awssm-evergreen_pac_default"> 
            <div class="lb-carousel-item-inner"> 
             <div class="lb-bg-right-bottom-cover lb-xlarge-radius lb-none-v-margin lb-box lb-hover-p-feature-shadow" style="padding-top:40px; padding-left:40px; padding-bottom:40px; background-image:url('https://d1.awsstatic.com/Digital Marketing/House/Hero/Default_Start-Building.00e592e4495f5ead1aba337232d3a0e9d49f0c1c.png'); margin-bottom:32px; height:560px; padding-right:40px;"> 
              <div class="lb-small-radius lb-tiny-iblock lb-none-pad lb-none-v-margin lb-box" style="background-color:#0D1421; padding-top:4px; padding-left:8px; padding-bottom:4px; margin-bottom:70px; height:28px; padding-right:8px;"> 
               <h6 id="AWS_Free_Tier" class="lb-txt-none lb-txt-14 lb-none-v-margin lb-h6 lb-title" style="color:#FFFFFF;"> AWS Free Tier</h6> 
              </div> 
              <div class="lb-bottom-full-width lb-abs-pos-wrapper" style="bottom:40px;"> 
               <div class="lb-none-pad lb-none-v-margin lb-grid lb-row lb-row-max-large lb-snap"> 
                <div class="lb-col lb-tiny-24 lb-mid-16"> 
                 <h1 id="Start_Building_on_AWS_Today" class="lb-txt-normal lb-txt-none lb-txt-white lb-txt-28 lb-h1 lb-title" style="margin-top:70px; margin-bottom:36px;"> Start Building on AWS Today</h1> 
                 <div class="lb-txt-lead lb-rtxt" style="color:#FFFFFF;"> 
                  <p>Whether you're looking for compute power, database storage, content delivery, or other functionality, AWS has the services to help you build sophisticated applications with increased flexibility, scalability and reliability</p> 
                 </div> 
                </div> 
                <div class="lb-col lb-tiny-24 lb-mid-8"> 
                </div> 
               </div> 
               <div class="lb-none-pad lb-none-v-margin lb-xb-grid-wrap" style="padding-top:0px; padding-left:0px; padding-bottom:0px; margin-top:0px; margin-bottom:0px; padding-right:0px;"> 
                <div class="lb-xb-grid lb-row-max-none lb-snap lb-gutter-tinyOutsideCollapse lb-tiny-xb-1"> 
