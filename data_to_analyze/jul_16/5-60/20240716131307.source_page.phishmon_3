var _model ={"BgCacheVal":"","ClientSettings":{"Pn":{"Cn":1,"St":0,"Qs":0,"Prod":"P"},"Sc":{"Cn":1,"St":0,"Qs":0,"Prod":"H"},"Qz":{"Cn":1,"St":0,"Qs":0,"Prod":"T"},"Ap":true,"Mute":true,"Lad":"2024-07-16T00:00:00Z","Iotd":0,"Gwb":0,"Tns":0,"Dft":null,"Mvs":0,"Flt":0,"Imp":1,"Tobn":0},"MediaContents":[{"ImageContent":{"Description":"A arqueologia pode não ser a primeira coisa que lhe vem à mente quando você pensa em festivais, mas o Festival de Arqueologia Britânica, que acontece de 13 a 28 de julho, está aqui para mudar isso. Desde sua criação em 1990, ele se transformou em um evento de duas semanas. Ele motiva os entusiastas da arqueologia a explorar escavações e maravilhas do patrimônio. O tema deste ano, \u0022Arqueologia e Comunidade\u0022, convida os entusiastas a uma série de eventos presenciais e virtuais preparados por organizações de patrimônio, sociedades locais e cidadãos apaixonados.","Image":{"Url":"/th?id=OHR.AncientOrkney_PT-BR0835986378_1920x1080.webp","Wallpaper":"/th?id=OHR.AncientOrkney_PT-BR0835986378_1920x1200.jpg\u0026rf=LaDigue_1920x1200.jpg","Downloadable":true},"Headline":"Explorando o passado","Title":"O assentamento neolítico de Skara Brae, Orkney, Escócia","Copyright":"© Paul Williams - FunkyStock/Getty Images","SocialGood":null,"MapLink":{"Url":"","Link":""},"QuickFact":{"MainText":"","LinkUrl":"","LinkText":""},"TriviaUrl":"/search?q=Bing+homepage+quiz\u0026filters=WQOskey:\u0022HPQuiz_20240716_AncientOrkney\u0022\u0026FORM=HPQUIZ","BackstageUrl":"/search?q=Arqueologia+Brit%c3%a2nica\u0026form=hpcapt\u0026filters=HpDate:\u002220240716_0300\u0022","TriviaId":"HPQuiz_20240716_AncientOrkney"},"AudioContent":null,"VideoContent":null,"Ssd":"20240716_0300","FullDateString":"jul. 16, 2024"}],"LocStrings":{"LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD":"Image of the day","LOC_HOMEPAGE_VERTICAL_SCROLL_IOTD_LEARN_MORE":"Learn more","LOC_HOMEPAGE_VERTICAL_SCROLL_DONATE_NOW":"Donate now","LOC_HOMEPAGE_VERTICAL_SCROLL_FACT":"Quick fact:","LOC_HOMEPAGE_GALLERY_