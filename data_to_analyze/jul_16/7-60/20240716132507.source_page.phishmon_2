   <div class="lp-block lp-section lp-section--name-vip lp-section-vip lp-pb-48 lp-pb-72@M lp-pt-72 lp-pt-96@M is-style-gray-100-mono" style="overflow:hidden;--lp-background:19, 25, 30" data-section-name="vip">
