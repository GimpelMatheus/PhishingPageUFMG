top?image_search=1","searchPageRedirectDisable":"True","serpIframeUrl":"https://yandex.ru/search/?promo=mail.ru","testIframeScriptUrl":"https://iframe.s3.yandex.net/$$version$$/morda-desktop.js","testSerpIframeScriptUrl":"https://iframe.s3.yandex.net/$$version$$/search.js"},"searchConfigSerp":{"searchPageRedirectDisable":"True","testSerpIframeScriptUrl":"https://iframe.s3.yandex.net/$$version$$/search.js"},"searchIframeScriptUrl":"","searchIframeUrl":"","searchSerpIframeScriptUrl":"","searchSerpIframeUrl":"","separateLogoAndSearch":"blue","showDarkSwitchPromo":false,"showFooterHelp":true,"showSportWidget":true,"signupButtonText":"","socialWidgetsDesign2022":true,"themeAutoDetect":true,"uberAdPosition":"top","unblockByXhrReloadCount":10,"unreadCounterBlink":false,"unreadTextBlink":false,"updateAdOnAuthChange":true,"updateAdOnTimer":true,"updateAdTimerDelay":30,"updateAdTimerInnactive":300,"visitCookieConfig":{"aliases":["horo","games","combo","youla","tv"],"expires":60},"weatherAnimateCanStop":true,"weatherAnimationDelay":2000,"weatherIconsRedesign":true,"weatherMoreArrow":true,"widgetHover":true},"oid":"6dn2gMf1DNZn982WKrK2u","segments":{"_segment1":"3544_9426_Holdback Q2_Control Group","_segment2":"holdback_7_Control","_segment3":"holdback_16_Control"},"segment":"3544_9426_Holdback Q2_Control Group","short_segments":"9426.w"},data: {"slidotype":null,"isWhiteline":true,"isCrossNav":true,"region":{"city":"Бразилиа","countryId":"234","manualRegionNotRussia":true},"accident":null,"horo":{"bid":27780713,"version":2,"icon":"all","title":"Гороскоп","desc":"Будет требовать больших усилий","descFull":"Старайтесь сохранять спокойствие или хотя бы скрывать свое волнение, если в начале дня что-то пойдет не по плану. Это время действительно может оказаться сложным, особенно для тех, кто прежде легко добивался успеха во многих делах. Даже решение привычных простых задач будет требовать больших усилий, чем обычно. Но влияние позитивных тенденций с каждым часом будет становиться все сильней и заметней. Вторая половина дня подойдет для семейных дел, общения с родственниками, обсуждения общих планов. Не возникнет серьезных разногласий между теми, кто живет или просто проводит много времени вместе.","url":"https://horo.mail.ru/prediction/today/?frommail=1","showPixel":"https://rs.mail.ru/pixel/AACx-QFzN8OfBKbvq7BHBCkRTbxpTvtWfYtDo5sC8qADUicAdyX91qY1A3K55zMCEcLABXHaGQ5rl3KZhMbmNYH3hmr9D0Zcb_rgluEwwjPgZgy_djcXdpJU-mqV1mfO2Q6bAVYDoAkV-8kvKniI8BSwZv5Hq-Vq6--_fDHgxR9--uEXw9b5OwoiAAAA0WHgTqdyjp6QlXtwICroadSMKGO08Tn2zSJm99iqczx__FC3cNh7KX21FS4yvlRM.gif","clickPixel":"https://rs.mail.ru/pixel/AACx-QFzN8OfBKbvq7BHBCkRTbxpTvtWfYtDo5sC8qADUicAdyX91qY1A3K55zMCEcLABXHaGQ5rl3KZhMbmNYH3hmr9D0Zcb_rgluEwwjPgZgy_djcXdpJU-mqV1mfO2Q6bAVYDoAkV-8kvKniI8BSwZv5Hq-Vq6--_fDHgxR9--uEXw-v4CSsiAAAAQEmMd1nk879QC_bRUypbrn_JRlSBWa9NIW_5-C66_Zk2zgxYuDpnIwT4uALkIFF2.gif","allZodiacs":[{"title":"Овен","url":"https://horo.mail.ru/prediction/aries/today/?frommail=1","icon":"aries","description":"Проявите инициативу в делах, поделитесь своими идеями, расскажите о своих идеях тем, кто может помочь в их реализации. Это день, когда быть на виду особенно полезно. Чем больше людей узнает о ваших победах и планах, тем быстрее вы получите интересные предложения или заключите выгодные сделки. При этом день вряд ли обойдется без разногласий. Они возможны и на работе, и дома. Поводом для спора может стать любой пустяк; вам не захочется пойти даже на незначительные уступки. Но если вы чуть смягчитесь и прислушаетесь к тому, что говорят окружающие, отношения вскоре наладятся."},{"title":"Телец","url":"https://horo.mail.ru/prediction/taurus/today/?frommail=1","icon":"taurus","description":"Не сдавайтесь, если будет трудновато. Это как раз тот день, когда ваше знаменитое упорство может оказаться особенно полезным. Именно благодаря ему вы справитесь с тем, что оказалось не по силам другим, решите сложные вопросы. Очень многим понравится ваша настойчивость. Не исключено, что люди, которые раньше почти не замечали вас, предложат что-то интересное. Близкие сегодня будут обращаться за помощью и советами, ожидая от вас поддержки и обычной деликатности. Однако некоторые Тельцы попытаются навязать окружающим свою волю, и это может стать причиной проблем в отношениях. Если вы дадите немного свободы тем, кого любите, то сразу почувствуете себя лучше."},{"title":"Близнецы","url":"https://horo.mail.ru/prediction/gemini/today/?frommail=1","icon":"gemini","description":"Сразу беритесь за что-нибудь важное и сложное. У вас есть шанс отлично справиться с серьезным делом, достичь давно поставленной цели. Удачное стечение обстоятельств позволит некоторым Близнецам решать финансовые вопросы, в последнее время приносившие немало беспокойства. Ладить с окружающими будет легко. Неважно, как долго вы знакомы: получится и найти общий язык, и договориться о каких-то совместных планах. Хорошо пройдут романтические свидания. Человек, которого вы сегодня встретите впервые, оценит ваше чувство юмора."},{"title":"Рак","url":"https://horo.mail.ru/prediction/cancer/today/?frommail=1","icon":"cancer","description":"Не пытайтесь решить все вопросы сразу. Сегодня особенно важно действовать последовательно, не пытаться заниматься одновременно работой и личными делами. Очень важно как можно раньше расставить приоритеты. Как только вы это сделаете, станет ясно, что нужно предпринять. Довольно сложным будет эмоциональный фон этого дня, поэтому некоторые Раки могут переживать из-за пустяков или тревожиться, сами толком не понимая, почему. Вечером ситуация изменится к лучшему, наступит благоприятное время для общения с самыми близкими, семейных дел, дружеских встреч."},{"title":"Лев","url":"https://horo.mail.ru/prediction/leo/today/?frommail=1","icon":"leo","description":"Отбросьте ложную скромность и позвольте окружающим увидеть, с каким замечательным человеком они имеют дело. Сегодня вы будете особенно привлекательны, поэтому весьма вероятны знакомства, с которых могут начаться и дружеские, и романтические отношения. На работе едва ли возникнут какие-то серьезные проблемы. Но если это все же случится, проверенные союзники помогут преодолеть трудности. Внимательнее нужно быть Львам, которые давно состоят в стабильном браке или отношениях, которыми дорожат. Сами того не желая, вы рискуете дать близкому человеку повод для ревности. Лучше избегать любых неоднозначных ситуаций."},{"title":"Дева","url":"https://horo.mail.ru/prediction/virgo/today/?frommail=1","icon":"virgo","description":"Говорите прямо. Возможно, кому-то ваши высказывания покажутся резковатыми, но люди, чье мнение для вас действительно важно, оценят искренность. Деловые переговоры могут пройти напряженнее, чем вы ожидали, но завершатся вполне удачно. День окажется неплохим для работы и других полезных занятий. Вы предпочтете не действовать проверенными методами, а найти собственный путь к цели. Именно это позволит быстро добиться нужного результата, опередить конкурентов и обезоружить недоброжелателей. А вот во всем, что касается личных отношений, нужно избегать спешки. Тут вам наверняка потребуется время, чтобы принять верные решения."},{"title":"Весы","url":"https://horo.mail.ru/prediction/libra/today/?frommail=1","icon":"libra","description":"Будьте готовы взять на себя ответственность за других, проявить лидерские качества. Сегодня у вас отлично будет получаться руководить окружающими, вдохновлять тех, кто сомневается в себе, поддерживать тех, кто оказался в сложной ситуации. На это обратят внимание люди, которые могут помочь в развитии вашей карьеры. Не упустите шанс произвести на них впечатление! Дома будет больше забот, чем обычно. Не исключены мелкие недоразумения. Но если вы не станете переживать из-за них, постараетесь сохранить спокойствие и будете решать одну проблему за другой, все сложится удачно."},{"title":"Скорпион","url":"https://horo.mail.ru/prediction/scorpio/today/?frommail=1","icon":"scorpio","description":"Принимайте решения самостоятельно, именно так вы сможете добиться того, к чему давно стремились. Советы едва ли окажутся толковыми, даже если давать их будут люди, чей опыт не раз был вам полезен. Однако не стоит совершенно отказываться от общения с коллегами и деловыми партнерами, ведь у вас будет шанс узнать от них что-то интересное. День благоприятен с точки зрения семейных отношений. Если в последнее время было трудновато найти общий язык с родственниками, сегодня вы оставите разногласия в прошлом, будете понимать друг друга с полуслова. Хорошо сложатся небольшие поездки."},{"title":"Стрелец","url":"https://horo.mail.ru/prediction/sagittarius/today/?frommail=1","icon":"sagittarius","description":"Не упустите шанс решить важный вопрос в начале дня. Влияние позитивных тенденций в это время будет особенно сильным, и добиться нужного результата окажется проще, чем вы ожидали. Не исключены полезные знакомства. Стрельцы, размышлявшие о том, чтобы сменить работу, получат заманчивые предложения. Общение с близкими будет радовать, если вы не станете раздражаться из-за мелочей. Какие-то недоразумение возможны, но гораздо важнее то, что вы всегда будете чувствовать поддержку дорогих людей, знать, что они на вашей стороне."},{"title":"Козерог","url":"https://horo.mail.ru/prediction/capricorn/today/?frommail=1","icon":"capricorn","description":"Как бы вы ни были уверены в своей правоте, прислушайтесь к мнению человека, которому доверяете. Сегодня вам легко будет выдать желаемое за действительное или довериться первому впечатлению, не допуская даже мысли о том, что оно может оказаться неверным. Друзья, близкие, просто хорошие знакомые постараются удержать вас от необдуманных поступков. День больше подойдет для решения знакомых задач, чем для того, чтобы браться за что-то новое. Козерогам, которые заняты учебой, нужно будет потрудиться. Не все будет даваться легко, но вы найдете ответы на многие вопросы."},{"title":"Водолей","url":"https://horo.mail.ru/prediction/aquarius/today/?frommail=1","icon":"aquarius","description":"Дайте волю воображению. Именно способность придумывать что-то новое, находить нестандартные решения позволит вам сегодня добиться успеха, справиться со многими непростыми задачами. Ваш творческий подход на многих произведет впечатление. Люди, которые раньше были настроены не слишком дружелюбно, сами проявят инициативу в общении. Ладить с близкими утром будет сложнее, чем обычно. Не всегда им будут понятны ваши намерения, мотивы ваших поступков. Однако со временем усилится влияние позитивных тенденций, отношения наладятся."},{"title":"Рыбы","url":"https://horo.mail.ru/prediction/pisces/today/?frommail=1","icon":"pisces","description":"Будьте настойчивы: без этого сейчас вряд ли удастся добиться успеха. День вас ждет интересный, отлично подходящий для новых начинаний, обещающий яркие впечатления тем, кто в последнее время скучал. Вероятен прогресс именно в тех делах, которым вы в последнее время уделяли много внимания. День будет особенно благоприятным для тех, кто занимается научными исследованиями, учится или учит других. До и к другим Рыбам звезды будут благосклонны. Многих Рыб ждут интересные встречи и приятные знакомства. Одно из них может получить романтическое продолжение."}],"color":"#333","background":"#ffffff","border":"#333"},"newYearHoro":null,"news":{"id":29285023,"bid":29285023,"showPixel":"https://rs.mail.ru/pixel/AACx-QFzN8OfBKbvq7BHBCkRTbxpTvtWfYtDo5sC8qADUicAdyX91qY1A3K55zMCEcLABXHaGQ5rl3KZhMbmNYH3hmr9D0Zcb_rgluEwwjPgZgy_djcXdpJU-mqV1mfO2Q6bAVYDoAkV-8kvKniI8BSwZv5Hq-Vq6--_fDHgxR9--uEXw7CiGAsnAAAAcIhviro-kksYqpXOIzo9maGoPuB96M8tGEbibTDZgRUVevWjYSKkfB1tbzrkUFzW.gif","general":[{"id":61960937,"nid":413891045,"url":"https://news.mail.ru/incident/61960937/?frommail=1","title":"Из-за аварии на ГРЭС без света остались более 115 тысяч человек","source_name":"РБК","desc":"На Гусиноозерской ГРЭС отключился один из трех энергоблоков, сообщил глава республики Алексей Цыденов","img":"https://r.mradx.net/pictures/64/97D2A0.jpg","img_2x":"https://r.mradx.net/pictures/64/97D2A0.jpg"},{"id":61960682,"nid":413889905,"url":"https://finance.mail.ru/2024-07-16/dolg-ivleevoy-pered-federalnoy-nalogovoy-sluzhboy-vyros-vdvoe-61960682/?fromnews=1&frommail=1","title":"Долг Ивлеевой перед Федеральной налоговой службой вырос вдвое","source_name":"Известия"},{"id":61956768,"nid":413891559,"url":"https://news.mail.ru/politics/61956768/?frommail=1","title":"«Катастрофа для Украины»: кого Трамп выбрал вице-президентом","source_name":"Новости Mail.ru"},{"id":61960312,"nid":413890338,"url":"https://news.mail.ru/incident/61960312/?frommail=1","title":"Гладков назвал число погибших жителей с начала военной операции","source_name":"РБК"},{"id":61958883,"nid":413887075,"url":"https://news.mail.ru/politics/61958883/?frommail=1","title":"Назван размер награды за первый уничтоженный F-16","source_name":"Lenta.Ru"},{"id":61961226,"nid":413891852,"url":"https://finance.mail.ru/2024-07-16/stoimost-proezda-po-trasse-m-11-s-uchetom-novogo-uchastka-sostavit-ot-3-2-tys-rubley-61961226/?fromnews=1&frommail=1","title":"«Автодор» назвал цену за проезд по новому обходу Твери на М-11","source_name":"Известия"},{"id":61929582,"nid":413880570,"url":"https://finance.mail.ru/2024-07-16/kak-poluchit-naibolshuyu-dohodnost-po-vkladu-61929582/?fromnews=1&frommail=1","title":"«Новой волны ждать не стоит»: что будет с вкладами в 2024 году","source_name":"Новости Mail.ru"},{"id":61959076,"nid":413889906,"url":"https://news.mail.ru/politics/61959076/?frommail=1","title":"Трамп заявил, что покушение повлияло на него","source_name":"© РИА Новости"},{"id":61956383,"nid":413882433,"url":"https://news.mail.ru/politics/61956383/?frommail=1","title":"NYT: Украина планирует завершить конфликт с Россией переговорами","source_name":"© РИА Новости"},{"id":61954566,"nid":413876185,"url":"https://news.mail.ru/politics/61954566/?frommail=1","title":"Орбан раскрыл планы Трампа на Украину","source_name":"Lenta.Ru"},{"id":61953774,"nid":413888088,"url":"https://finance.mail.ru/2024-07-16/kakie-vyplaty-polozhe