    </div> <!-- #5. es.wikipedia.org - 164,633,000 views/day --> 
    <div class="central-featured-lang lang5" lang="es" dir="ltr"> <a id="js-link-box-es" href="//es.wikipedia.org/" title="Español — Wikipedia — La enciclopedia libre" class="link-box" data-slogan="La enciclopedia libre"> <strong>Español</strong> <small>1.965.000+ <span>artículos</span></small> </a> 
    </div> <!-- #6. fr.wikipedia.org - 142,897,000 views/day --> 
    <div class="central-featured-lang lang6" lang="fr" dir="ltr"> <a id="js-link-box-fr" href="//fr.wikipedia.org/" title="français — Wikipédia — L’encyclopédie libre" class="link-box" data-slogan="L’encyclopédie libre"> <strong>Français</strong> <small>2 621 000+ <span>articles</span></small> </a> 
    </div> <!-- #7. zh.wikipedia.org - 106,959,000 views/day --> 
