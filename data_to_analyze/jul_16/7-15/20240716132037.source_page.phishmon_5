       </figure> 
       <figure class="wp-block-image size-full">
        <img width="2640" height="484" src="https://wordpress.org/files/2023/10/showcase-middle-row.png" alt="" class="wp-image-22641" srcset="https://i0.wp.com/wordpress.org/files/2023/10/showcase-middle-row.png?w=2640&amp;ssl=1 2640w, https://i0.wp.com/wordpress.org/files/2023/10/showcase-middle-row.png?resize=300%2C55&amp;ssl=1 300w, https://i0.wp.com/wordpress.org/files/2023/10/showcase-middle-row.png?resize=1024%2C188&amp;ssl=1 1024w, https://i0.wp.com/wordpress.org/files/2023/10/showcase-middle-row.png?resize=768%2C141&amp;ssl=1 768w, https://i0.wp.com/wordpress.org/files/2023/10/showcase-middle-row.png?resize=1536%2C282&amp;ssl=1 1536w, https://i0.wp.com/wordpress.org/files/2023/10/showcase-middle-row.png?resize=2048%2C375&amp;ssl=1 2048w" sizes="(max-width: 2640px) 100vw, 2640px">
