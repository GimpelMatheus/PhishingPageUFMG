   <div class="lp-block lp-section lp-section--name-testimonials lp-section-testimonial lp-pb-72 lp-pt-96 is-style-gray-0-mono" data-section-name="testimonials">
    <div class="lp-section__content"> 
     <div class="lp-block lp-content lp-wrapper lp-wrapper--layout-medium-plus lp-pb-6"> 
      <p class="lp-margin-bottom-5 has-small-font-size">WordPress to the <strong class="is-core-span">&lt;Core&gt;</strong></p> 
      <h2 class="wp-block-heading">At WordPress.com we’re committed to the open web. With the help of our customers, we devote&nbsp;<a href="https://href.li/?https://wordpress.org/five-for-the-future/">5% of our time</a>&nbsp;to pushing forward the free, open source WordPress code and community.</h2> 
     </div> 
     <div class="lp-block lp-content lp-wrapper lp-wrapper--layout-center"> 
      <div class="lp-block lp-button is-mobile-full-width lpc lpc-cta-core"> 
       <div class="wp-block-button">
        <a class="wp-block-button__link wp-element-button" href="https://wordpress.com/start?ref=logged-out-homepage-lp">Start creating</a>
       </div> 
      </div> 
     </div> 
    </div>
   </div> 
   <div class="lp-block lp-section lp-section--name-support lp-pb-72 lp-pt-72 lp-section-support is-style-blue-0-mono" style="overflow:hidden" data-section-name="support">
    <div class="lp-section__content"> 
     <div class="lp-block lp-content lp-wrapper lp-wrapper--layout-wide lp-grid lp-grid--section lp-grid--align-center">
      <div class="lp-block lp-block--has-breakpoints lp-block--has-breakpoint-XS lp-block--has-breakpoint-S lp-container">
