  <script>self.__next_f.push([1,"c:[\"$\",\"div\",null,{\"className\":\"flex min-h-screen flex-col\",\"children\":[[\"$\",\"$Le\",null,{\"enabled\":false,\"initialData\":{\"logo\":{\"desktop\":{\"file\":{\"asset\":{\"url\":\"https://cdn.sanity.io/images/fuvbjjlp/production/36cbc8ae92c7711afb9ab1ec9f7174863f4d7c19-22x24.svg\",\"metadata\":{\"blurHash\":\"e05#hSt7D%fQRj-;j[fQj[ofD%ofD%RjM{xuWBt7ayWB9Ft7D%ayIU\",\"lqip\":\"$f\",\"dimensions\":{\"width\":22,\"height\":24}}}},\"alt\":\"Desktop Unity Logo\"},\"mobile\":{\"file\":{\"asset\":{\"url\":\"https://cdn.sanity.io/images/fuvbjjlp/production/fa8e822f74dc0dc469801f15ac53859e00318ee2-264x97.svg\",\"metadata\":{\"blurHash\":\"D009jvfQfQfQfQfQfQfQfQfQ\",\"lqip\":\"data:image/png;base64,\",\"dimensions\":{\"width\":264,\"height\":97}}}},\"alt\":\"Mobile Unity Logo\"}},\"navigation\":[{\"title\":\"Products\",\"fieldLink\":{\"linkReference\":{\"title\":\"Products\",\"href\":{\"current\":\"/products\"},\"target\":\"_self\"}},\"groups\":[{\"title\":\"Products\",\"fieldLink\":{\"linkReference\":null},\"links\":[{\"title\":\"Unity Engine\",\"description\":\"Empowers creators to build games, apps, or immersive experiences, featuring high-quality graphics, end-to-end multiplayer capabilities, multi-platform support, and AI enhancements\",\"fieldLink\":{\"linkReference\":{\"title\":\"Unity Engine\",\"href\":{\"current\":\"/products/unity-engine\"},\"target\":\"_self\"}}},{\"title\":\"Unity Cloud\",\"description\":\"Makes real-time 3D creation and consumption more accessible, collaborative, and connected\",\"fieldLink\":{\"linkReference\":{\"title\":\"Unity Cloud PDP\",\"href\":{\"current\":\"/products/unity-cloud\"},\"target\":\"_self\"}}},{\"title\":\"Unity Grow\",\"description\":\"Enables monetizing and acquiring users as well as publishing games, featuring LevelPlay, ad networks, TapJoy Offerwall, on-device advertising, and Supersonic for scaling mobile games into successful businesses\",\"fieldLink\":{\"linkReference\":{\"title\":\"Grow\",\"href\":{\"current\":\"/grow\"},\"target\":\"_self\"}}},{\"title\":\"Unity Publishing\",\"description\":\"Supersonic from Unity provides publishing technology empowering you to scale your game profitably.\",\"fieldLink\":{\"linkReference\":{\"title\":\"Supersonic Solution\",\"href\":{\"current\":\"/solutions/supersonic\"},\"target\":\"_self\"}}}]}]},{\"title\":\"Solutions\",\"fieldLink\":{\"linkReference\":{\"title\":\"Use cases\",\"href\":{\"current\":\"/use-cases\"},\"target\":\"_self\"}},\"groups\":[{\"title\":\"Solutions\",\"fieldLink\":{\"linkReference\":null},\"links\":[{\"title\":\"Use cases\",\"description\":\"Learn how Unity can solve your toughest problems, unlock new opportunities, and bring your ideas to life.\",\"fieldLink\":{\"linkReference\":{\"title\":\"Use cases\",\"href\":{\"current\":\"/use-cases\"},\"target\":\"_self\"}}},{\"title\":\"Industries\",\"description\":\"From video games to manufacturing, Unity offers tools, services, and support that fit your business.\",\"fieldLink\":{\"linkReference\":{\"title\":\"Industry Solution\",\"href\":{\"current\":\"/industry\"},\"target\":\"_self\"}}}]}]},{\"title\":\"Resources\",\"fieldLink\":{\"linkReference\":{\"title\":\"Unity Resources\",\"href\":{\"current\":\"/resources\"},\"target\":\"_self\"}},\"groups\":[{\"title\":\"Resources\",\"fieldLink\":{\"linkReference\":null},\"links\":[{\"title\":\"Documentation\",\"description\":\"Explore the definitive information source for all of Unity’s features, UI, and workflows.\",\"fieldLink\":{\"linkReference\":{\"title\":\"Unity Documentation\",\"href\":{\"current\":\"https://docs.unity.com\"},\"target\":\"_self\"}}},{\"title\":\"Developer tools\",\"description\":\"Find the latest downloads, releases, and other resources here. Explore the tools we have to benefit your project – documentation, roadmaps, Knowledge Base, Issue Tracker, and more.\",\"fieldLink\":{\"linkReference\":{\"title\":\"Developer Tools\",\"href\":{\"current\":\"/developer-tools\"},\"target\":\"_self\"}}},{\"title\":\"Resources\",\"description\":\"Discover what’s possible with Unity and how to get the most out of our tools. Read case studies and industry reports, get expert guidance in best practices, and watch demos and technical deep dives.\",\"fieldLink\":{\"linkReference\":{\"title\":\"Unity Resources\",\"href\":{\"current\":\"/resources\"},\"target\":\"_self\"}}}]}]},{\"title\":\"Community\",\"fieldLink\":{\"linkReference\":{\"title\":\"Community\",\"href\":{\"current\":\"/community\"},\"target\":\"_self\"}},\"groups\":[{\"title\":\"Community\",\"fieldLink\":{\"linkReference\":null},\"links\":[{\"title\":\"Forums\",\"description\":\"Dive into the Unity forums, your go-to destination for all Unity development discussions. Connect with fellow creators, get support from experienced developers, and participate in the latest conversations.\",\"fieldLink\":{\"linkReference\":{\"title\":\"Unity Forum\",\"href\":{\"current\":\"https://forum.unity.com/\"},\"target\":\"_self\"}}},{\"title\":\"Discord\",\"description\":\"Jump into the Unity Discord community, where game development is at the heart of every conversation. Join fellow creators in fresh discussions, get support from devs, share projects, and discover endless inspiration for your Unity projects.\",\"fieldLink\":{\"linkReference\":{\"title\":\"Unity Discord\",\"href\":{\"current\":\"https://discord.com/invite/unity\"},\"target\":\"_blank\"}}},{\"title\":\"Discussions\",\"description\":\"Join the action by posting questions and finding answers. Along the way, you’ll see awesome projects, meet your peers, and maybe even find someone to help your project or team.\",\"fieldLink\":{\"linkReference\":{\"title\":\"Unity Discussions\",\"href\":{\"current\":\"https://discussions.unity.com/\"},\"target\":\"_self\"}}},{\"title\":\"Events\",\"description\":\"Around the world, the Unity community gathers to share what we’ve learned, what we’re working on, and how you can take your projects further using Unity. Find an event near you.\",\"fieldLink\":{\"linkReference\":{\"title\":\"Events Hub\",\"href\":{\"current\":\"/events-hub\"},\"target\":\"_self\"}}}]}]},{\"title\":\"Learn\",\"fieldLink\":{\"linkReference\":{\"title\":\"Learn\",\"href\":{\"current\":\"/learn\"},\"target\":\"_self\"}},\"groups\":[{\"title\":\"Learn\",\"fieldLink\":{\"linkReference\":null},\"links\":[{\"title\":\"Unity Learn\",\"description\":\"Advance your Unity skills with award-winning tutorials, hands-on projects, and in-depth courses. Access over 750 hours of on-demand learning content for creators at every skill level.\",\"fieldLink\":{\"linkReference\":{\"title\":\"Unity Learn\",\"href\":{\"current\":\"https://learn.unity.com/\"},\"target\":\"_self\"}}},{\"title\":\"Getting started\",\"description\":\"New to Unity? Start your creative journey from software installation and setup to learning the basics needed to create your first Unity projects.\",\"fieldLink\":{\"linkReference\":{\"title\":\"Get started with Unity\",\"href\":{\"current\":\"/learn/get-started\"},\"target\":\"_self\"}}},{\"title\":\"Professional Training\",\"description\":\"Increase your productivity and improve workflows with Unity Professional Training. Whether you are a gaming or industry professional, our live expert-led courses and premium On-Demand Training platform will teach your team how to best succeed with Unity.\",\"fieldLink\":{\"linkReference\":{\"title\":\"Learn Professionals\",\"href\":{\"current\":\"/learn/professionals\"},\"target\":\"_self\"}}},{\"title\":\"Education\",\"description\":\"Enable students with the tools and learning experiences that will maximize their success with Unity.\",\"fieldLink\":{\"linkReference\":{\"title\":\"Learn\",\"href\":{\"current\":\"/learn\"},\"target\":\"_self\"}}}]}]},{\"title\":\"Support\",\"fieldLink\":{\"linkReference\":{\"title\":\"Support Services\",\"href\":{\"current\":\"/support-services\"},\"target\":\"_self\"}},\"groups\":[{\"title\":\"Support\",\"field