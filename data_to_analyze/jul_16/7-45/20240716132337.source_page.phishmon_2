              <div class="tabs-panel" id="panel-qr-code"> 
               <div class="tabintro"> 
                <p class="h4">Create a QR Code</p> 
                <p class="p1">No credit card required.</p> 
               </div> 
               <div class="tabform"> 
                <form id="form-qr-code" class="freehook-form" method="GET" action="/a/sign_up" novalidate autocomplete="off"> 
                 <div class="inner-content grid-x grid-margin-x grid-padding-x-off form-content align-middle"> 
