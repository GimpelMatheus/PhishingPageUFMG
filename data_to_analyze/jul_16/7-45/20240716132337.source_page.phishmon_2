            <div style="position: relative; height: 0; width: inherit; padding-bottom: 79.135%; overflow: hidden;">
             <img alt="Great video calling with Skype" class="imageFluid imageFluidDesktop x-hidden-focus" id="web_skype_banner_big_screens" src="https://secure.skypeassets.com/content/dam/scom/blogs/groupnewhero.png" style="position: absolute; top: 0; left:0; width: 100%;" title="Great video calling with Skype">
            </div> 
