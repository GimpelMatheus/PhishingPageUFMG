.scale-up-animation.tp-yt-paper-tooltip {
  transform: scale(0);
  opacity: var(--paper-tooltip-opacity, 0.9);
  animation-delay: var(--paper-tooltip-delay-in, 500ms);
  animation-name: keyFrameScaleUp;
  animation-iteration-count: 1;
