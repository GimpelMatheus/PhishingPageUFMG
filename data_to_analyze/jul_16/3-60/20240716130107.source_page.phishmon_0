tp-yt-app-header {
  position: relative;
  display: block;
  transition-timing-function: linear;
  transition-property: -webkit-transform;
  transition-property: transform;
}

tp-yt-app-header::before {
  position: absolute;
  right: 0px;
  bottom: -5px;
  left: 0px;
  width: 100%;
  height: 5px;
  content: "";
  transition: opacity 0.4s;
  pointer-events: none;
  opacity: 0;
  box-shadow: inset 0px 5px 6px -3px rgba(0, 0, 0, 0.4);
  will-change: opacity;
}

tp-yt-app-header[shadow]::before {
  opacity: 1;
}

#background.tp-yt-app-header {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  overflow: hidden;
}

#backgroundFrontLayer.tp-yt-app-header,#backgroundRearLayer.tp-yt-app-header {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  height: 100%;
  pointer-events: none;
  background-size: cover;
}

#backgroundFrontLayer.tp-yt-app-header {
  background-image: var(--app-header-background-front-layer-background-image);
  background-position: var(--app-header-background-front-layer-background-position);
  background-repeat: var(--app-header-background-front-layer-background-repeat);
  background-size: var(--app-header-background-front-layer-background-size);
}

#backgroundRearLayer.tp-yt-app-header {
  opacity: 0;
}

#contentContainer.tp-yt-app-header {
  position: relative;
  width: 100%;
